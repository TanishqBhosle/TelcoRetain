# ============================================================
# Telecom Retention Platform — Environment Variables
# Copy to .env and fill in your values
# ============================================================

# --- Application ---
APP_NAME="Telecom Customer Retention Intelligence Platform"
APP_VERSION="1.0.0"
DEBUG=false
ENVIRONMENT=production

# --- Database (Neon PostgreSQL or local Postgres) ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/telco_retain
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# --- JWT Security ---
SECRET_KEY=your-super-secret-key-min-32-chars-change-in-prod
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Redis (optional — uses in-memory fallback if not set) ---
REDIS_URL=redis://localhost:6379/0

# --- CORS ---
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","https://your-frontend-domain.com"]

# --- Rate Limiting ---
RATE_LIMIT_AUTH=10/minute
RATE_LIMIT_PREDICTION=60/minute
RATE_LIMIT_DEFAULT=120/minute

# --- ML Artifacts ---
ML_ARTIFACTS_PATH=./ml/artifacts
ML_MODEL_VERSION=v1.0

# --- Email (optional — auto-verifies if not set) ---
SENDGRID_API_KEY=
EMAIL_FROM=noreply@telecom-retention.com
EMAIL_VERIFICATION_REQUIRED=false

# --- Admin ---
FIRST_ADMIN_EMAIL=admin@telecom-retention.com
FIRST_ADMIN_PASSWORD=Admin@1234
FIRST_ADMIN_NAME=System Admin

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT=json
